# Each parallel Playwright worker authenticates as a distinct user: worker N uses the (N+1)th pool entry.
# Provide at least as many users as --workers (default 2). Worker 0 falls back to the legacy single
# E2E_TEST_EMAIL/E2E_TEST_PASSWORD if no numbered pool is set (serial runs only).
E2E_TEST_EMAIL_1=your-test-user-1@example.com
E2E_TEST_PASSWORD_1=your-test-password-1
E2E_TEST_EMAIL_2=your-test-user-2@example.com
E2E_TEST_PASSWORD_2=your-test-password-2

# Legacy single-user fallback (worker 0 only; run with --workers=1):
# E2E_TEST_EMAIL=your-test-user@example.com
# E2E_TEST_PASSWORD=your-test-password
