{
  "_README": "Reference template only - Claude Code does NOT load this file. Hooks are opt-in and inactive by default. To activate, copy ONE profile's hooks object below into .claude/settings.local.json (gitignored). See ai-harness/hooks/README.md.",
  "_profiles": {
    "minimal": {
      "hooks": {
        "SessionStart": [
          {
            "hooks": [
              { "type": "command", "command": "powershell -ExecutionPolicy Bypass -File ai-harness/hooks/scripts/session-start.ps1" }
            ]
          }
        ]
      }
    },
    "standard": {
      "hooks": {
        "SessionStart": [
          {
            "hooks": [
              { "type": "command", "command": "powershell -ExecutionPolicy Bypass -File ai-harness/hooks/scripts/session-start.ps1" }
            ]
          }
        ],
        "PreToolUse": [
          {
            "matcher": "Bash",
            "hooks": [
              { "type": "command", "command": "powershell -ExecutionPolicy Bypass -File ai-harness/hooks/scripts/command-boundary-check.ps1" }
            ]
          }
        ]
      }
    },
    "strict": {
      "hooks": {
        "SessionStart": [
          {
            "hooks": [
              { "type": "command", "command": "powershell -ExecutionPolicy Bypass -File ai-harness/hooks/scripts/session-start.ps1" }
            ]
          }
        ],
        "PreToolUse": [
          {
            "matcher": "Bash",
            "hooks": [
              { "type": "command", "command": "powershell -ExecutionPolicy Bypass -File ai-harness/hooks/scripts/command-boundary-check.ps1" }
            ]
          },
          {
            "matcher": "Edit|Write|NotebookEdit",
            "hooks": [
              { "type": "command", "command": "powershell -ExecutionPolicy Bypass -File ai-harness/hooks/scripts/edit-boundary-check.ps1" }
            ]
          }
        ]
      }
    }
  }
}
